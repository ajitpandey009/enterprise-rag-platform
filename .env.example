# ============================================================
# Enterprise RAG Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Database
DB_URL=jdbc:postgresql://localhost:5432/ragplatform
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ragplatform
DB_USERNAME=raguser
DB_PASSWORD=ragpassword

# LLM — Ollama (default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LLM — OpenAI (activate with spring.profiles.active=openai)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# JWT Security
JWT_SECRET=c2VjdXJlLWVudGVycHJpc2UtcmFnLXBsYXRmb3JtLWp3dC1zZWNyZXQta2V5LXRoYXQtaXMtbG9uZy1lbm91Z2g=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# RAG Settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
EMBEDDING_DIMENSION=768
RAG_MAX_RESULTS=5
RAG_MIN_SCORE=0.5

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Spring Profile
SPRING_PROFILES_ACTIVE=default
